# IntentWin Production Environment Variables
# ===========================================
# Copy this file and fill in your production values.
# Do NOT commit the actual .env.production file!
#
# For Vercel deployment, add these in the Vercel dashboard:
# Project Settings > Environment Variables

# ============================================
# SUPABASE (Required)
# ============================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Public URL - safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key - safe to expose (restricted by RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - NEVER expose publicly! Server-side only.
# This key bypasses RLS - use with extreme caution.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# ANTHROPIC / CLAUDE AI (Required)
# ============================================
# Get your API key from: https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Override the default model (claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================
# VOYAGE AI - Embeddings (Required for RAG)
# ============================================
# Get your API key from: https://dash.voyageai.com/

VOYAGE_API_KEY=pa-...

# Embedding model configuration
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024

# ============================================
# STRIPE BILLING (Required)
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Use LIVE keys for production (sk_live_, pk_live_)

# Secret key - server-side only, NEVER expose
STRIPE_SECRET_KEY=sk_live_...

# Publishable key - safe for browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret - get from Stripe webhook endpoint config
# Dashboard > Developers > Webhooks > Your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# STRIPE PRODUCT IDS (Required)
# ============================================
# Create these products/prices in Stripe Dashboard or via API
# Then add the price IDs here

# Starter plan - $49/month
STRIPE_STARTER_PRICE_ID=price_...

# Professional plan - $149/month
STRIPE_PROFESSIONAL_PRICE_ID=price_...

# Enterprise plan - $499/month
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ============================================
# APPLICATION URLS (Required)
# ============================================
# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://intentwin.com

# ============================================
# OPTIONAL: ERROR MONITORING
# ============================================
# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/1234567

# ============================================
# OPTIONAL: ANALYTICS
# ============================================
# PostHog, Mixpanel, or other analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
