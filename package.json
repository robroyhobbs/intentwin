{
  "name": "intentwin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src __tests__ scripts middleware.ts next.config.ts",
    "hygiene:check": "bash scripts/check-repo-hygiene.sh",
    "test": "vitest run",
    "test:unit": "vitest run src/lib/",
    "test:integration": "vitest run __tests__/integration/",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results/junit.xml",
    "analyze": "ANALYZE=true next build",
    "notify:llms": "bash scripts/notify-llms.sh",
    "repo:new:intentbid": "bash scripts/create-intentbid-repo.sh",
    "guardrails:boundaries": "bash scripts/check-boundaries.sh",
    "guardrails:complexity:changed": "bash scripts/check-changed-complexity.sh",
    "perf:baseline": "bash scripts/capture-performance-baseline.sh",
    "perf:check": "node scripts/check-performance-thresholds.mjs",
    "smoke:prod": "bash scripts/smoke-production.sh"
  },
