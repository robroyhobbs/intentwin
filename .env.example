# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_SCORING_MODEL=gemini-2.5-flash
# GEMINI_REVIEW_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Kimi (optional — if set, Kimi is primary for section generation with Gemini fallback)
# KIMI_API_KEY=
# KIMI_MODEL=kimi-k2-thinking
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# Embeddings (Voyage AI)
VOYAGE_API_KEY=pa-your-key
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
ADMIN_EMAIL=rob@intentwin.com

# App URL (used for Stripe redirects, sitemap, robots.txt)
NEXT_PUBLIC_APP_URL=https://intentwin.com

# Email sender (defaults to IntentBid <onboarding@resend.dev>)
EMAIL_FROM=IntentBid <onboarding@resend.dev>

# OpenAI (Quality Review — GPT-4o judge)
OPENAI_API_KEY=sk-your-openai-key

# Groq (Quality Review — Llama 3.3 judge, free tier)
GROQ_API_KEY=gsk_your-groq-key

# Mistral (Quality Review — Mistral Small judge, free tier)
MISTRAL_API_KEY=your-mistral-key

# Demo mode (optional, set DEMO_PASSWORD to enable /demo-login)
# DEMO_PASSWORD=

# Intelligence Service (optional — enhances bid scoring and section generation with real procurement data)
# INTELLIGENCE_API_URL=http://localhost:3100
# INTELLIGENCE_SERVICE_KEY=your-service-key

# Helicone Observability (optional — proxies Voyage AI calls for cost/latency tracking)
# HELICONE_API_KEY=sk-helicone-your-key

# PDF Export (Gotenberg on Cloud Run — replaces Puppeteer/Chromium in serverless)
# Deploy: ./scripts/deploy-gotenberg.sh
# Falls back to local Chrome for development if not set.
# GOTENBERG_URL=https://intentbid-pdf-renderer-xxxxx-ue.a.run.app

# Cron Jobs (Vercel)
CRON_SECRET=
